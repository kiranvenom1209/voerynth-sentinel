# Vœrynth Sentinel runtime configuration
# Copy this file to config.env and fill in the real values.

# Home Assistant target
HA_HOST=homeassistant.local
HA_SSH_USER=ha
HA_SSH_PORT=22
# Pin the HA SSH server key. Accepts either a full known_hosts line or: ssh-ed25519 AAAA...
HA_SSH_HOST_KEY=

# Tuya power relay
TUYA_DEVICE_ID=replace-with-device-id
TUYA_DEVICE_IP=replace-with-plug-ip
TUYA_LOCAL_KEY=replace-with-local-key
TUYA_VERSION=3.4

# Encrypted backup restore
BACKUP_PASS=replace-with-backup-password
PREFERRED_RESTORE_LOCATION=Local_NAS

# Optional remote probe
NABU_CASA_URL=
ENABLE_REMOTE_CHECK=false
NABU_CASA_TIMEOUT=8

# Web/dashboard binding
BIND_HOST=0.0.0.0
DASHBOARD_HOST=127.0.0.1
PORT=8080

# General watchdog timing
CHECK_INTERVAL=10
REQUEST_TIMEOUT=4
SSH_INVESTIGATION_TIMEOUT=5
HARD_FAILURE_THRESHOLD=3
SOFT_FAILURE_GRACE=2
SOFT_FAILURE_TIMEOUT=120
BOOT_GRACE_PERIOD=180
STARTUP_GRACE_PERIOD=120
INTENTIONAL_REBOOT_GRACE_PERIOD=300
POST_RESTORE_BOOT_GRACE_PERIOD=400
POWER_OFF_SECONDS=12
MAX_REBOOTS_PER_HOUR=3
REBOOT_WINDOW_SECONDS=3600
COOLDOWN_AFTER_REBOOT=300

# Safety
DRY_RUN=false